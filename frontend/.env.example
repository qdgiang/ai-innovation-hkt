# Frontend env contract (mirrors infra/.env.example + compose).
#
# PLACEHOLDER MODE (no public backend yet): leave BOTH unset — SSR fetches
# fail fast and every page renders its designed empty state.
#
# Once the API is publicly hosted, set both to its URL — and note the API
# needs CORS middleware added before browser-side writes work cross-origin
# (tracked follow-up; SSR reads work without it).

# What the BROWSER dials (baked into the client bundle at build time).
NEXT_PUBLIC_API_URL=

# What server components dial at render time (server-only, not exposed).
# In compose this is http://api:8000; on Vercel it's the same public URL
# as NEXT_PUBLIC_API_URL.
API_URL_INTERNAL=
