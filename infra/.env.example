# architecture.md §Configuration — the documented env contract.
DATABASE_URL=postgresql+psycopg://evermind:evermind@db:5432/evermind
AI_BASE_URL=https://api.ai-box.vn/v1
AI_MODEL=deepseek-v4-pro
# NEVER commit a real key here — this file is tracked. Put the key in infra/.env
# (git-ignored). The key that briefly lived on this line is burned: rotate it.
AI_API_KEY=
EXTRACTION_BATCH_SIZE=20
EXTRACTION_INTERVAL_SEC=30
EXTRACTION_SETTLE_SEC=120
CONFIDENCE_TAU=0.8
PROMOTION_SWEEP_SEC=60
ORG_TIMEZONE=Asia/Ho_Chi_Minh
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_MS=2000
REPLAY_PACE_MS=800
GRACE_WINDOW_MIN=10
NUDGE_AFTER_HOURS=48

# frontend
NEXT_PUBLIC_API_URL=http://localhost:8000